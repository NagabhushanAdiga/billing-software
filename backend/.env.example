PORT=4000
NODE_ENV=development

# SQLite database file (relative to backend folder)
DATABASE_PATH=./data/billing.db

# Change in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated origins for CORS
CORS_ORIGIN=http://localhost:5173

# Vercel / Turso (required on Vercel — get free DB at https://turso.tech)
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# First admin account (created on npm run db:reset)
INITIAL_ADMIN_USERNAME=naga
INITIAL_ADMIN_PASSWORD=12345
INITIAL_ADMIN_NAME=Naga
